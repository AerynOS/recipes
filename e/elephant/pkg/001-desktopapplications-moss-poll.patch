+
+// mossIsActive reports whether the system is managed by the moss package
+// manager. Moss atomically replaces /usr on every transaction, which
+// invalidates inotify watches bound to the old directory inodes.
+func mossIsActive() bool {
+	_, err := os.Stat("/.moss/db/state")
+	return err == nil
+}
+
+// usePoll reports whether the polling watcher should be used instead of
+// inotify. Polling is forced when poll_interval > 0, or auto-selected when
+// a moss installation is detected.
+func usePoll() bool {
+	if config.PollInterval > 0 {
+		return true
+	}
+	return mossIsActive()
+}
+
+// effectivePollInterval returns the poll interval to use in seconds.
+func effectivePollInterval() int {
+	if config.PollInterval > 0 {
+		return config.PollInterval
+	}
+	return 3
+}
+
+// collectSnapshot walks root and records the mtime of every .desktop file
+// found. Uses filepath.WalkDir which is path-based rather than inode-based,
+// so it correctly reflects the current filesystem state after a moss
+// transaction replaces the /usr directory tree atomically.
+func collectSnapshot(root string, snap fileSnapshot) {
+	filepath.WalkDir(root, func(path string, d fs.DirEntry, err error) error {
+		if err != nil || d.IsDir() || filepath.Ext(path) != ".desktop" {
+			return nil
+		}
+		info, err := d.Info()
+		if err != nil {
+			return nil
+		}
+		snap[path] = info.ModTime()
+		return nil
+	})
+}
+
+// pollFiles replaces watchFiles on systems where inotify is unreliable.
+// It runs for the lifetime of the provider, periodically re-scanning all
+// XDG application dirs by path and diffing against the previous snapshot
+// to detect additions, removals, and modifications.
+func pollFiles() {
+	interval := time.Duration(effectivePollInterval()) * time.Second
+
+	ticker := time.NewTicker(interval)
+	defer ticker.Stop()
+
+	for range ticker.C {
+		newSnap := make(fileSnapshot)
+		for _, root := range dirs {
+			if _, err := os.Stat(root); err != nil {
+				continue
+			}
+			collectSnapshot(root, newSnap)
+		}
+
+		changed := false
+
+		snapshotMu.Lock()
+		for path, newMtime := range newSnap {
+			oldMtime, existed := snapshot[path]
+			if !existed {
+				handleFileCreate(path)
+				changed = true
+			} else if newMtime != oldMtime {
+				handleFileUpdate(path)
+				changed = true
+			}
+		}
+		for path := range snapshot {
+			if _, stillExists := newSnap[path]; !stillExists {
+				handleFileRemove(path)
+				changed = true
+			}
+		}
+		snapshot = newSnap
+		snapshotMu.Unlock()
+
+		if changed {
+			handlers.ProviderUpdated <- Name
+		}
+	}
+}
