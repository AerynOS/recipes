/** Human readable report. This is not consumed by boulder */
{
	"manifest-version": "0.2",
	"packages": {
		"rclone": {
			"build-depends": [
				"binary(go)"
			],
			"depends": [
				"interpreter(/usr/lib/ld-linux-x86-64.so.2(x86_64))",
				"soname(libc.so.6(x86_64))"
			],
			"files": [
				"/usr/bin/rclone",
				"/usr/sbin/mount.rclone",
				"/usr/sbin/rclonefs",
				"/usr/share/bash-completion/completions/rclone",
				"/usr/share/fish/vendor_completions.d/rclone.fish",
				"/usr/share/man/man1/rclone.1",
				"/usr/share/zsh/site-functions/_rclone"
			],
			"name": "rclone",
			"provides": [
				"binary(rclone)",
				"sysbinary(mount.rclone)",
				"sysbinary(rclonefs)"
			]
		}
	},
	"source-name": "rclone",
	"source-release": "2",
	"source-version": "1.74.1"
}
