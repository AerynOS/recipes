From 667e48b6a590f4bb74bad9e8c6916bc397da913a Mon Sep 17 00:00:00 2001
From: Kyle Gospodnetich <me@kylegospodneti.ch>
Date: Wed, 27 May 2026 19:37:24 -0700
Subject: [PATCH] feat: wifi-backend-switching cargo feature (default off)

---
 steamos-manager/Cargo.toml            |  4 ++++
 steamos-manager/src/bin/steamosctl.rs |  2 ++
 steamos-manager/src/manager/root.rs   |  7 ++++--
 steamos-manager/src/manager/user.rs   |  2 ++
 steamos-manager/src/wifi.rs           | 34 ++++++++++++++++-----------
 5 files changed, 33 insertions(+), 16 deletions(-)

diff --git a/steamos-manager/Cargo.toml b/steamos-manager/Cargo.toml
index 68078ee..ddc5a55 100644
--- a/steamos-manager/Cargo.toml
+++ b/steamos-manager/Cargo.toml
@@ -38,3 +38,7 @@ udev = { version = "^0.9.3", features = ["send", "sync"] }
 xdg = "3.0"
 zbus = { version = "5", default-features = false, features = ["tokio"] }
 zbus_xml = "5"
+
+[features]
+default = []
+wifi-backend-switching = []
diff --git a/steamos-manager/src/bin/steamosctl.rs b/steamos-manager/src/bin/steamosctl.rs
index adaa355..2be9ed3 100644
--- a/steamos-manager/src/bin/steamosctl.rs
+++ b/steamos-manager/src/bin/steamosctl.rs
@@ -168,6 +168,7 @@ enum Commands {
     SuggestedDefaultPerformanceProfile,
 
     /// Set the Wi-Fi backend, if possible
