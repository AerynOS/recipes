From f6b7315006aa6c6d412258044b18976db07be75c Mon Sep 17 00:00:00 2001
From: honjow <honjow311@gmail.com>
Date: Fri, 13 Mar 2026 02:28:22 +0800
Subject: [PATCH 01/17] power: Use /sys/class/power_supply for acpi_sb battery
 charge limit

The previous path /sys/bus/acpi/drivers/battery/PNP0C0A:00/power_supply
requires the ACPI battery driver to be bound, which is not always the
case. Use /sys/class/power_supply instead, which works regardless of
which driver created the power_supply device.
---
 steamos-manager/src/power.rs | 5 +----
 1 file changed, 1 insertion(+), 4 deletions(-)

diff --git a/steamos-manager/src/power.rs b/steamos-manager/src/power.rs
index f36f6f3..638d360 100644
--- a/steamos-manager/src/power.rs
+++ b/steamos-manager/src/power.rs
@@ -62,7 +62,7 @@ const TDP_LIMIT1: &str = "power1_cap";
 const TDP_LIMIT2: &str = "power2_cap";
 
 #[cfg(not(test))]
-const SB_PATH: &str = "/sys/bus/acpi/drivers/battery/PNP0C0A:00/power_supply";
+const SB_PATH: &str = "/sys/class/power_supply";
 #[cfg(test)]
 const SB_PATH: &str = "power_supply";
 pub const BATTERY_DEFAULT_SUGGESTED_MINIMUM_LIMIT: i32 = 10;
@@ -671,9 +671,6 @@ async fn find_battery_charge_path() -> Result<PathBuf> {
         BatteryChargeLimitMethod::AcpiSb => {
             let mut dir = read_dir(path(SB_PATH)).await?;
             while let Some(entry) = dir.next_entry().await? {
