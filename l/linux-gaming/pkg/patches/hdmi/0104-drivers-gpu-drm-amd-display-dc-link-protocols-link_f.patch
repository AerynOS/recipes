From: =?UTF-8?q?Micha=C5=82=20Kope=C4=87?= <michal@nozomi.space>
Date: Wed, 25 Feb 2026 02:42:06 +0100
Subject: [PATCH 104/109] 
 drivers/gpu/drm/amd/display/dc/link/protocols/link_frl_training.c: Delay
 before finalizing training

---
 .../drm/amd/display/dc/link/protocols/link_frl_training.c   | 6 ++++--
 1 file changed, 4 insertions(+), 2 deletions(-)

diff --git a/drivers/gpu/drm/amd/display/dc/link/protocols/link_frl_training.c b/drivers/gpu/drm/amd/display/dc/link/protocols/link_frl_training.c
index 4d547b6e2633..16bbf28a9b34 100644
--- a/drivers/gpu/drm/amd/display/dc/link/protocols/link_frl_training.c
+++ b/drivers/gpu/drm/amd/display/dc/link/protocols/link_frl_training.c
@@ -172,6 +172,8 @@ bool dc_link_perform_frl_training(struct dc_link *link,
 
 		if (lane == lane_count) {
 			enc->funcs->set_training_enable(enc, false);
+			/* Delay to let the sink settle after clearing SCDC_UPDATE_0 */
+			msleep(FRL_POLL_DELAY_MS);
 			for (post_training_timeout = 0;
 				post_training_timeout < FRL_MAX_POLLS;
 				post_training_timeout++) {
@@ -270,7 +272,7 @@ bool dc_link_perform_frl_training_with_retries(struct dc_link *link,
 		}
 
 		DC_LOG_HW_LINK_TRAINING("FRL: Training attempt %d failed! Will attempt rate %d next",
-			i, link->cur_link_settings.frl_rate);
+			i + 1, link->cur_link_settings.frl_rate);
 	}
 
 	return success;
@@ -592,4 +594,4 @@ bool hdmi_decide_link_settings(
 	}
 
 	return false;
-}
\ No newline at end of file
+}
