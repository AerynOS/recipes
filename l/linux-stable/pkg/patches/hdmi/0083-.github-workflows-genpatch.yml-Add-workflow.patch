From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Micha=C5=82=20Kope=C4=87?= <michal@nozomi.space>
Date: Fri, 20 Feb 2026 04:24:21 +0100
Subject: [PATCH 083/109] .github/workflows/genpatch.yml: Add workflow

---
 .github/workflows/genpatch.yml | 22 ++++++++++++++++++++++
 .gitignore                     |  2 +-
 2 files changed, 23 insertions(+), 1 deletion(-)
 create mode 100644 .github/workflows/genpatch.yml

diff --git a/.github/workflows/genpatch.yml b/.github/workflows/genpatch.yml
new file mode 100644
index 000000000000..75731cf60b2e
--- /dev/null
+++ b/.github/workflows/genpatch.yml
@@ -0,0 +1,22 @@
+name: Generate patch
+on:
+  push:
+    branches: hdmi_frl
+
+jobs:
+  generate_patch:
+    runs-on: ubuntu-24.04
+    steps:
+      - name: Checkout repository
+        uses: actions/checkout@v4
+        with:
+          ref: hdmi_frl
+          fetch-depth: 0
+      - name: Generate patch
+        run: git diff origin/master > 0001-amdgpu-frl.patch
+      - name: Save artifacts
+        uses: actions/upload-artifact@v4
+        with:
+          name: "Patch"
+          path: 0001-amdgpu-frl.patch
+          retention-days: 30
diff --git a/.gitignore b/.gitignore
index 3a7241c941f5..d5dbc2628e85 100644
--- a/.gitignore
+++ b/.gitignore
@@ -10,7 +10,7 @@
 #
 # Normal rules (sorted alphabetically)
 #
-.*
+.
 *.a
 *.asn1.[ch]
 *.bin
