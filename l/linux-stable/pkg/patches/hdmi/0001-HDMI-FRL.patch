+	SR(HDMI_STREAM_ENC_CLOCK_RAMP_ADJUSTER_FIFO_STATUS_CONTROL2),         \
+								              \
+	/* TB encoder - control and pixel format */                           \
+	SR(HDMI_TB_ENC_CONTROL), SR(HDMI_TB_ENC_PIXEL_FORMAT),                \
+	SR(HDMI_TB_ENC_MODE), SR(HDMI_TB_ENC_DB_CONTROL),                     \
