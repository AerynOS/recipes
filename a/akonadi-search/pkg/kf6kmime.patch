From da96921072d5516c48a617a0307c68f117a96589 Mon Sep 17 00:00:00 2001
From: Volker Krause <vkrause@kde.org>
Date: Wed, 15 Apr 2026 18:05:32 +0200
Subject: [PATCH] Add forward compatibility with KMime from KDE Frameworks

---
 CMakeLists.txt                         |  7 +++++--
 KPimAkonadiSearchConfig.cmake.in       | 18 ++++++++++++++----
 agent/CMakeLists.txt                   |  2 +-
 agent/autotests/CMakeLists.txt         |  2 +-
 agent/tests/CMakeLists.txt             |  2 +-
 akonadiplugin/autotests/CMakeLists.txt |  2 +-
 lib/tests/CMakeLists.txt               |  2 +-
 7 files changed, 24 insertions(+), 11 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index ae976e3c..5961e55e 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -128,7 +128,6 @@ set(AKONADISEARCH_VERSION ${PIM_VERSION})
 
 set(AKONADI_VERSION "6.7.2")
 set(AKONADI_MIMELIB_VERSION "6.7.2")
-set(KMIME_LIB_VERSION "6.7.2")
 set(QT_REQUIRED_VERSION "6.9.0")
 set(KPIM_MIME_VERSION "6.7.2")
 set(KTEXTADDONS_MIN_VERSION "2.0.0")
@@ -171,7 +170,11 @@ set_package_properties(
 
 find_package(KPim6Akonadi ${AKONADI_VERSION} CONFIG REQUIRED)
 find_package(KF6Contacts ${KF_MIN_VERSION} CONFIG REQUIRED)
-find_package(KPim6Mime ${KPIM_MIME_VERSION} CONFIG REQUIRED)
+find_package(KF6Mime ${KF_MIN_VERSION} CONFIG)
+if(NOT TARGET KF6::Mime)
+    find_package(KPim6Mime ${KPIM_MIME_VERSION} CONFIG REQUIRED)
+    add_library(KF6::Mime ALIAS KPim6::Mime)
+endif()
 find_package(KPim6AkonadiMime ${AKONADI_MIMELIB_VERSION} CONFIG REQUIRED)
 find_package(KF6CalendarCore ${KF_MIN_VERSION} CONFIG REQUIRED)
 find_package(KF6TextUtils ${KTEXTADDONS_MIN_VERSION} CONFIG REQUIRED)
diff --git a/KPimAkonadiSearchConfig.cmake.in b/KPimAkonadiSearchConfig.cmake.in
index d80c3cee..49b13506 100644
--- a/KPimAkonadiSearchConfig.cmake.in
+++ b/KPimAkonadiSearchConfig.cmake.in
@@ -16,10 +16,20 @@ find_dependency(
     KF6Contacts
     "@KF_MIN_VERSION@"
 )
-find_dependency(
-    KPim6Mime
-    "@KMIME_LIB_VERSION@"
-)
+if(@KF6Mime_FOUND@)
+    find_dependency(
+        KF6Mime
+        "@KF_MIN_VERSION@"
+    )
+else()
+    find_dependency(
+        KPim6Mime
+        "@KPIM_MIME_VERSION@"
+    )
+    if(NOT TARGET KF6::Mime)
+        add_library(KF6::Mime ALIAS KPim6::Mime)
+    endif()
+endif()
 find_dependency(
     KPim6AkonadiMime
     "@AKONADI_MIMELIB_VERSION@"
diff --git a/agent/CMakeLists.txt b/agent/CMakeLists.txt
index 8c372ba7..50e916ec 100644
--- a/agent/CMakeLists.txt
+++ b/agent/CMakeLists.txt
@@ -122,7 +122,7 @@ target_link_libraries(
         Qt::Core
         KPim6::AkonadiCore
         KPim6::AkonadiMime
-        KPim6::Mime
+        KF6::Mime
         KF6::Contacts
         KPim6::AkonadiAgentBase
         KF6::CalendarCore
diff --git a/agent/autotests/CMakeLists.txt b/agent/autotests/CMakeLists.txt
index 062eacbf..3b4e8acc 100644
--- a/agent/autotests/CMakeLists.txt
+++ b/agent/autotests/CMakeLists.txt
@@ -23,7 +23,7 @@ set(indexer_LIBS
     KPim6::AkonadiCore
     KPim6::AkonadiMime
     KPim6::AkonadiAgentBase
-    KPim6::Mime
+    KF6::Mime
     KF6::Contacts
     KF6::CalendarCore
     KPim6::AkonadiSearchPIM
diff --git a/agent/tests/CMakeLists.txt b/agent/tests/CMakeLists.txt
index b2a800c8..f78f6e66 100644
--- a/agent/tests/CMakeLists.txt
+++ b/agent/tests/CMakeLists.txt
@@ -13,7 +13,7 @@ target_link_libraries(
     Qt::Test
     KPim6::AkonadiCore
     KPim6::AkonadiMime
-    KPim6::Mime
+    KF6::Mime
     KPim6::AkonadiSearchPIM
     KPim6::AkonadiSearchXapian
     KF6::Codecs
diff --git a/akonadiplugin/autotests/CMakeLists.txt b/akonadiplugin/autotests/CMakeLists.txt
index c4b9bb86..316e92fc 100644
--- a/akonadiplugin/autotests/CMakeLists.txt
+++ b/akonadiplugin/autotests/CMakeLists.txt
@@ -37,7 +37,7 @@ target_link_libraries(
     Qt::Test
     KPim6::AkonadiCore
     KPim6::AkonadiMime
-    KPim6::Mime
+    KF6::Mime
     KF6::Contacts
     ${XAPIAN_LIBRARIES}
     KF6::CalendarCore
 
