-    #[allow(clippy::unnecessary_cast)]
-    const MODE_RW_UGO: u32 = (S_IRUSR | S_IWUSR | S_IRGRP | S_IWGRP | S_IROTH | S_IWOTH) as u32;
-    #[allow(clippy::unnecessary_cast)]
-    const S_IRWXUGO: u32 = (S_IRWXU | S_IRWXG | S_IRWXO) as u32;
+    match (was_created, mode) {
