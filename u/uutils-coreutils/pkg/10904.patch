-        (if explicit {
-            if is_dir { S_IRWXUGO } else { MODE_RW_UGO }
-        } else {
-            source_mode & S_IRWXUGO
-        }) & !umask
-    } else {
-        source_mode & S_IRWXUGO
+            let mode = if explicit {
+                if is_dir { S_IRWXUGO } else { MODE_RW_UGO }
+            } else {
+                source_mode & S_IRWXUGO
+            };
+            Some(mode & !umask)
+        }
     }
