-#[cfg(unix)]
-fn test_cp_not_existing_default_file() {
-    use std::io;
-
-    let scene = TestScenario::new(util_name!());
-    let at = &scene.fixtures;
-
-    scene.cmd("touch").arg("f1").succeeds();
-    scene.cmd("chmod").arg("770").arg("f1").succeeds();
-
-    scene
