+    let mut command = scene.ucmd();
+    match preserve {
+        Some(true) => command.arg("--preserve=mode"),
+        Some(false) => command.arg("--no-preserve=mode"),
+        _ => &mut command,
+    }
+    .umask(0o700)
+    .arg("f1")
+    .arg("f2")
+    .set_stdout(io::stdout())
+    .succeeds();
 
-    let f2_mode = at.metadata("f2").mode();
