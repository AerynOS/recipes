From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Reilly Brogan <reilly@reillybrogan.com>
Date: Fri, 3 Apr 2026 14:31:38 -0500
Subject: [PATCH] lld compat

LLD is compatible enough with GNU LD for newt's purposes

---
 configure.ac | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/configure.ac b/configure.ac
index a25f9a2..02f5bcb 100644
--- a/configure.ac
+++ b/configure.ac
@@ -24,7 +24,8 @@ AC_CHECK_SIZEOF([void *])
 AC_MSG_CHECKING([for GNU ld])
 LD=$($CC -print-prog-name=ld 2>&5)
 
-if test $($LD -v 2>&1 | $ac_cv_path_GREP -c "GNU ld") = 0; then
+if test $($LD -v 2>&1 | $ac_cv_path_GREP -c "GNU ld") = 0 -a \
+   $($LD -v 2>&1 | $ac_cv_path_GREP -c "compatible with GNU linkers") = 0; then
   # Not
   GNU_LD=""
   AC_MSG_RESULT([no])
