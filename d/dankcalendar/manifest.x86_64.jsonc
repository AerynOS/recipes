				"/usr/share/fish/vendor_completions.d/dcal.fish",
				"/usr/share/icons/hicolor/scalable/apps/dankcalendar.svg",
				"/usr/share/zsh/site-functions/_dcal"
			],
			"name": "dankcalendar",
			"provides": [
				"binary(dcal)"
			]
		}
	},
	"source-name": "dankcalendar",
