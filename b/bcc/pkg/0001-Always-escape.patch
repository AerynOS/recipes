From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Reilly Brogan <reilly@reillybrogan.com>
Date: Tue, 24 Mar 2026 17:36:52 -0500
Subject: [PATCH] Always escape

In order for system76-scheduler to work correctly it needs newline/tab chars to be escaped all the time
---
 libbpf-tools/execsnoop.c | 14 +++++++++-----
 1 file changed, 9 insertions(+), 5 deletions(-)

diff --git a/libbpf-tools/execsnoop.c b/libbpf-tools/execsnoop.c
index 6a663e53..3f8c6c55 100644
--- a/libbpf-tools/execsnoop.c
+++ b/libbpf-tools/execsnoop.c
@@ -171,11 +171,15 @@ static void time_since_start()
 	printf("%-8.3f", time_diff);
 }
 
-static void inline quoted_symbol(char c) {
+static void inline escape_symbol(char c, bool quote) {
 	switch(c) {
 		case '"':
-			putchar('\\');
-			putchar('"');
+			if (quote) {
+				putchar('\\');
+				putchar('"');
+			} else {
+				putchar(c);
+			}
 			break;
 		case '\t':
 			putchar('\\');
@@ -210,14 +214,14 @@ static void print_args(const struct event *e, bool quote)
 					putchar('"');
 				}
 			} else {
-				quoted_symbol(c);
+				escape_symbol(c, true);
 			}
 		} else {
 			if (c == '\0') {
 				args_counter++;
 				putchar(' ');
 			} else {
-				putchar(c);
+				escape_symbol(c, false);
 			}
 		}
 	}
