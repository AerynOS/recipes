From: Reilly Brogan <reilly@reillybrogan.com>
Date: Tue, 19 May 2026 12:50:12 -0500
Subject: [PATCH] stateless

---
 brush-core/src/sys/unix/fs.rs | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/brush-core/src/sys/unix/fs.rs b/brush-core/src/sys/unix/fs.rs
index f5b6968..f724ffe 100644
--- a/brush-core/src/sys/unix/fs.rs
+++ b/brush-core/src/sys/unix/fs.rs
@@ -227,12 +227,12 @@ pub const fn try_open_special_file(_path: &Path) -> Option<Result<std::fs::File,
 
 /// Returns the path to the system-wide shell profile script.
 pub fn get_system_profile_path() -> Option<&'static Path> {
-    Some(Path::new("/etc/profile"))
+    Some(Path::new("/usr/share/defaults/profile"))
 }
 
 /// Returns the path to the system-wide shell rc script.
 pub fn get_system_rc_path() -> Option<&'static Path> {
-    Some(Path::new("/etc/bash.bashrc"))
+    Some(Path::new("/usr/share/defaults/bashrc"))
 }
 
 /// Returns true if the string contains a path separator character.
