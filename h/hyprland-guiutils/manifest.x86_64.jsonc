/** Human readable report. This is not consumed by boulder */
{
	"manifest-version": "0.2",
	"packages": {
		"hyprland-guiutils": {
			"build-depends": [
				"pkgconfig(hyprlang)",
				"pkgconfig(hyprtoolkit)",
